<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_product_stock_notification_request_tree" model="ir.ui.view">
        <field name="name">product.stock.notification.request.list</field>
        <field name="model">product.stock.notification.request</field>
        <field name="arch" type="xml">
            <list string="Stock Notification Requests">
                <field name="create_date"/>
                <field name="product_id"/>
                <field name="email"/>
                <field name="requested_qty"/>
                <field name="state"/>
                <field name="sent_date"/>
                <field name="website_id"/>
            </list>
        </field>
    </record>

    <record id="view_product_stock_notification_request_form" model="ir.ui.view">
        <field name="name">product.stock.notification.request.form</field>
        <field name="model">product.stock.notification.request</field>
        <field name="arch" type="xml">
            <form string="Stock Notification Request">
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="product_tmpl_id" readonly="1"/>
                        <field name="email"/>
                        <field name="requested_qty"/>
                        <field name="state"/>
                        <field name="sent_date"/>
                        <field name="website_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_stock_notification_request" model="ir.actions.act_window">
        <field name="name">Stock Notification Requests</field>
        <field name="res_model">product.stock.notification.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
