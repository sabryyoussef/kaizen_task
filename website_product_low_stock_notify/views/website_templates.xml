<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="website_sale_product_notify_button" inherit_id="website_sale.product" name="Low stock notify button">
        <xpath expr="//div[@id='add_to_cart_wrap']" position="after">
            <t t-if="request and request.params.get('stock_notify_status')">
                <div class="mt-3">
                    <div
                        t-attf-class="alert #{'alert-success' if request.params.get('stock_notify_status') == 'success' else 'alert-danger'}"
                        role="alert"
                    >
                        <t t-esc="request.params.get('stock_notify_message')"/>
                    </div>
                </div>
            </t>
            <t t-set="current_variant" t-value="product.product_variant_id"/>
            <t t-if="current_variant and current_variant.qty_available &lt;= 0 and not product.allow_out_of_stock_order">
                <div class="mt-2">
                    <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" t-att-data-bs-target="'#stockNotifyModal-%s' % product.id">
                        Notify
                    </button>
                </div>
                <div class="modal fade" t-att-id="'stockNotifyModal-%s' % product.id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Notify me when back in stock</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"/>
                            </div>
                            <form action="/stock_notify/request" method="post">
                                <div class="modal-body">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="product_id" t-att-value="current_variant.id"/>
                                    <input type="hidden" name="redirect_url" t-att-value="request.httprequest.path"/>
                                    <div class="mb-3">
                                        <label class="form-label" for="stock_notify_email">Email</label>
                                        <input id="stock_notify_email" type="email" name="email" class="form-control" required="required"/>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label" for="stock_notify_qty">Quantity</label>
                                        <input id="stock_notify_qty" type="number" name="requested_qty" min="1" step="1" value="1" class="form-control" required="required"/>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    <button type="submit" class="btn btn-primary">Submit</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
